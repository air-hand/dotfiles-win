{{ $interactive := stdinIsATTY }}

{{ $git_name := "" }}
{{ $git_email := "" }}
{{ $local_llm_enabled := false }}
{{ $local_llm_cache_dir := "D:\\llama.cpp\\cache" }}
{{- if $interactive }}
{{ $git_name = promptStringOnce . "git_name" "What is your name for git." }}
{{ $git_email = promptStringOnce . "git_email" "What is your email for git." }}
{{ $local_llm_enabled = promptBoolOnce . "local_llm_enabled" "Do you want to enable local LLM integration." false }}
{{ $local_llm_cache_dir = promptStringOnce . "local_llm_cache_dir" "Where should llama.cpp cache downloaded models." $local_llm_cache_dir }}
{{- end }}

sourceDir = {{ .chezmoi.workingTree | quote }}

[data]
    git_name = {{ $git_name | quote }}
    git_email = {{ $git_email | quote }}
    local_llm_enabled = {{ $local_llm_enabled }}
    local_llm_cache_dir = {{ $local_llm_cache_dir | quote }}
{{ includeTemplate ".chezmoitemplates/local_llm.toml.tmpl" (dict "enabled" $local_llm_enabled "localLlamaCacheDir" $local_llm_cache_dir) }}

[interpreters.py]
    command = "mise.exe"
    args = ["exec", "uv", "--", "uv", "run", "--script"]
